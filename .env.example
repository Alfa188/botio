# ===========================================
# BotIO - Configuration
# ===========================================

# URL de la plateforme cible (text chat)
TARGET_URL=https://omegleweb.io

# URL de ton app à promouvoir
PROMO_URL=https://omefree.com

# -------------------------------------------
# FlareSolverr (bypass Cloudflare automatique)
# Docker: docker run -d -p 8191:8191 ghcr.io/flaresolverr/flaresolverr:latest
# -------------------------------------------
FLARESOLVERR_URL=http://localhost:8191

# -------------------------------------------
# Proxy Geonode Résidentiel (sticky session)
# Dashboard : https://app.geonode.com/residential-proxies
# -------------------------------------------
GEONODE_USERNAME=ton_username_geonode
GEONODE_PASSWORD=ton_password_geonode
GEONODE_HOST=premium.residential.proxies.geonode.com
GEONODE_PORT=9001
GEONODE_COUNTRY=US

# -------------------------------------------
# Instance (généré automatiquement si absent)
# En production, le deploy.sh injecte un ID unique par conteneur
# -------------------------------------------
INSTANCE_ID=

# -------------------------------------------
# Config Bot
# -------------------------------------------
MIN_TYPING_DELAY=1500
MAX_TYPING_DELAY=4000
MESSAGES_BEFORE_PROMO=3
DELAY_BETWEEN_CONVERSATIONS=5000

# Mode headless du navigateur (true en production, false pour debug)
HEADLESS=false

# Niveau de log (info, debug, warn, error)
LOG_LEVEL=info

# Nombre max de conversations par session
MAX_CONVERSATIONS=200
